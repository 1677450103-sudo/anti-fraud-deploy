# ========== DeepSeek（RAG 文字问答） ==========
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# ========== Doubao 图片识别（豆包视觉模型） ==========
DOUBAO_API_KEY=your_doubao_api_key_here
DOUBAO_MODEL=doubao-seed-2-0-pro-260215
DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3/responses

# ========== 讯飞语音识别（APPID / API Key / API Secret 四套通用） ==========
IFLYTEK_APP_ID=your_iflytek_app_id
IFLYTEK_API_KEY=your_iflytek_api_key
IFLYTEK_API_SECRET=your_iflytek_api_secret

# ========== RAG 模型配置 ==========
EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5
RERANKER_MODEL=BAAI/bge-reranker-base
RAG_TOP_K=15
RAG_RERANK_TOP=5
RAG_SCORE_THRESHOLD=0.0

# ========== ChromaDB 配置 ==========
CHROMA_COLLECTION=fraud_cases

# ========== 服务端口 ==========
PORT=80

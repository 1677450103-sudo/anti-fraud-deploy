# ========== RAG 模型配置 ==========
# Embedding 模型（HuggingFace repo ID，首次自动下载到缓存目录）
# 可选：BAAI/bge-small-zh-v1.5（24M/512维）/ BAAI/bge-base-zh-v1.5（102M/768维）
# 微调后改成本地路径：./models/bge-small-zh-v1.5
EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5

# 精排模型
# 可选英文轻量：cross-encoder/ms-marco-MiniLM-L-6-v2（22M）
# 中文推荐：BAAI/bge-reranker-base（110M）
# 微调后改成本地路径：./models/MiniLM-L-6-v2
RERANKER_MODEL=BAAI/bge-reranker-base

# RAG 检索参数
RAG_TOP_K=15        # Stage 1 粗召回数量（15条）
RAG_RERANK_TOP=5    # Stage 2 精排后返回数量
RAG_SCORE_THRESHOLD=0.0  # 精排相关性分数阈值（0~1，越高越严格）

# ========== ChromaDB 配置 ==========
CHROMA_COLLECTION=fraud_cases
